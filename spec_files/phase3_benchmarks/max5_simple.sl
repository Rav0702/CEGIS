(set-logic LIA)

(synth-fun max5 ((x0 Int) (x1 Int) (x2 Int) (x3 Int) (x4 Int)) Int)

(declare-var x0 Int)
(declare-var x1 Int)
(declare-var x2 Int)
(declare-var x3 Int)
(declare-var x4 Int)
(constraint (>= (max5 x0 x1 x2 x3 x4) x0))
(constraint (>= (max5 x0 x1 x2 x3 x4) x1))
(constraint (>= (max5 x0 x1 x2 x3 x4) x2))
(constraint (>= (max5 x0 x1 x2 x3 x4) x3))
(constraint (>= (max5 x0 x1 x2 x3 x4) x4))
(constraint (or (= x0 (max5 x0 x1 x2 x3 x4))
            (or (= x1 (max5 x0 x1 x2 x3 x4))
            (or (= x2 (max5 x0 x1 x2 x3 x4))
            (or (= x3 (max5 x0 x1 x2 x3 x4))
                (= x4 (max5 x0 x1 x2 x3 x4)))))))

(check-synth)
