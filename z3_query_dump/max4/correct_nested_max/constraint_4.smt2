(set-logic LIA)
(set-option :model.completion true)
(declare-const x0 Int)
(declare-const x1 Int)
(declare-const x2 Int)
(declare-const x3 Int)
(define-fun max4 ((x0 Int) (x1 Int) (x2 Int) (x3 Int)) Int (ite (>= (ite (>= x0 x1) x0 x1) (ite (>= x2 x3) x2 x3)) (ite (>= x0 x1) x0 x1) (ite (>= x2 x3) x2 x3)))
(assert (not (>= (max4 x0 x1 x2 x3) x3)))
(check-sat)
(get-value (x0 x1 x2 x3))
